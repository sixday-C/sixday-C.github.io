---
import { TWIKOO_CONFIG } from "@/config";

interface Props {
  path?: string;
}

const { path } = Astro.props;
const envId = TWIKOO_CONFIG.envId;
---

<div class="twikoo-wrapper max-w-3xl mx-auto px-4 mt-8">
  {
    envId
      ? (
          <div
            id="twikoo-comments"
            data-twikoo-root
            data-env-id={envId}
            data-path={path}
            data-lang={TWIKOO_CONFIG.lang}
            class="rounded-xl bg-base-100 p-4 sm:p-6 border border-base-300 shadow-md"
          />
        )
      : (
          <div class="rounded-xl bg-base-100 p-4 sm:p-6 border border-base-300 shadow-md">
            <p class="font-semibold mb-2">Twikoo 后端还没有配置</p>
            <p class="text-sm opacity-70 leading-6">
              部署 Twikoo 后端后，把完整地址填到 <code>src/config.ts</code>
              的 <code>TWIKOO_CONFIG.envId</code>，例如
              <code>https://sixdayc-twikoo.vercel.app</code>。
            </p>
          </div>
        )
  }
</div>

{
  envId && (
    <script is:inline>
      (() => {
        const loadTwikoo = () =>
          new Promise((resolve, reject) => {
            if (typeof window.twikoo?.init === "function") {
              resolve();
              return;
            }

            const existingScript = document.querySelector("[data-twikoo-cdn]");
            if (existingScript) {
              if (existingScript.dataset.loaded === "true") {
                reject(new Error("Twikoo loaded without exposing init()"));
                return;
              }
              existingScript.addEventListener("load", resolve, { once: true });
              existingScript.addEventListener("error", reject, { once: true });
              return;
            }

            const script = document.createElement("script");
            script.src =
              "https://cdn.jsdelivr.net/npm/twikoo@1.7.14/dist/twikoo.min.js";
            script.defer = true;
            script.dataset.twikooCdn = "true";
            script.addEventListener(
              "load",
              () => {
                script.dataset.loaded = "true";
                typeof window.twikoo?.init === "function"
                  ? resolve()
                  : reject(new Error("Twikoo loaded without exposing init()"));
              },
              { once: true },
            );
            script.addEventListener("error", reject, { once: true });
            document.head.appendChild(script);
          });

        const initTwikoo = async () => {
          const el = document.querySelector("[data-twikoo-root]");
          if (!el || el.dataset.twikooState) return;

          el.dataset.twikooState = "loading";

          try {
            await loadTwikoo();

            await window.twikoo.init({
              envId: el.dataset.envId,
              el: "#twikoo-comments",
              path: el.dataset.path || window.location.pathname,
              lang: el.dataset.lang || "zh-CN",
            });
            el.dataset.twikooState = "ready";
          } catch (error) {
            console.error("Failed to initialize Twikoo", error);
            el.dataset.twikooState = "error";
            el.innerHTML =
              '<p class="twikoo-error">评论区暂时加载失败，请稍后刷新页面重试。</p>';
          }
        };

        document.addEventListener("astro:page-load", initTwikoo);
        initTwikoo();
      })();
    </script>
  )
}

<style>
  .twikoo-wrapper {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--fallback-bc, oklch(var(--bc) / 0.1));
  }

  [data-theme="dracula"] .twikoo-wrapper {
    border-top-color: var(--fallback-bc, oklch(var(--bc) / 0.2));
  }

  .twikoo-wrapper :global(.tk-comments-container),
  .twikoo-wrapper :global(.tk-submit) {
    color: var(--fallback-bc, oklch(var(--bc)));
  }

  .twikoo-wrapper :global(.el-textarea__inner),
  .twikoo-wrapper :global(.el-input__inner) {
    background: var(--fallback-b1, oklch(var(--b1)));
    color: var(--fallback-bc, oklch(var(--bc)));
    border-color: var(--fallback-b3, oklch(var(--b3)));
  }

  .twikoo-wrapper :global(.el-button--primary) {
    background-color: var(--fallback-p, oklch(var(--p)));
    border-color: var(--fallback-p, oklch(var(--p)));
  }

  .twikoo-wrapper :global(.twikoo-error) {
    margin: 0;
    padding: 1rem 0;
    text-align: center;
    color: var(--fallback-er, oklch(var(--er)));
  }

  @media (max-width: 768px) {
    .twikoo-wrapper {
      margin-top: 1.5rem;
      padding-top: 1.5rem;
    }
  }
</style>
